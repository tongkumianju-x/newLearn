# LeetSnap 用户配置示例
# 实际配置位置：~/Library/Application Support/leetcode-snap/config.json
# 应用首次启动会自动创建，使用以下默认值；填好 API Key 后即可使用
#
# 不要把真实 Key 提交到仓库

# 全局快捷键
HOTKEY=F2
HOTKEY_OPACITY_UP=Up
HOTKEY_OPACITY_DOWN=Down

# 输出语言：python / cpp / java / go / javascript
LANGUAGE=go

# 引擎策略：true=优先本地题库  false=优先 LLM
PREFER_LOCAL_SOLVER=false

# LLM 协议：openai / anthropic
LLM_PROVIDER=openai

# 推荐服务商任选一个
# DeepSeek（首选，¥1/百万 token）
LLM_ENDPOINT=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
# 智谱 GLM（免费 glm-4-flash）
# LLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions
# LLM_MODEL=glm-4-flash
# Moonshot Kimi
# LLM_ENDPOINT=https://api.moonshot.cn/v1/chat/completions
# LLM_MODEL=moonshot-v1-8k

# !!! 这里填入你的 API Key（不要提交到 Git）!!!
LLM_API_KEY=
